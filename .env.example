# Mediu ANAF: "test" (sandbox) sau "production"
ANAF_ENV=test

# Credentiale OAuth2 ANAF (din aplicatia inregistrata la logincert.anaf.ro)
# Necesare DOAR daca vrei refresh automat cross-process; altfel se salveaza la callback.
ANAF_CLIENT_ID=
ANAF_CLIENT_SECRET=

# Directorul unde se salveaza token.json (implicit: ~/.anaf-efactura-mcp)
# ANAF_CONFIG_DIR=/path/custom

# Transport MCP: "stdio" (implicit, pt Claude Desktop) sau "sse" (pt rulare remote via HTTP)
MCP_TRANSPORT=stdio

# Port pentru modul SSE (ignorat in stdio)
MCP_PORT=3800